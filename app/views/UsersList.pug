extends layout
block content
    .main-content 
        h1 All Users 
        table(border=1)
            for item in data 
                tr  
                    td #{item.UserID}
                    td #{item.username}
                    td 
                        a(href='/User-single/' + item.UserID) #{item.realname} // allows users to click on profiel and be redirected to the profile page of the user